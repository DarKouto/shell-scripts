#!/usr/bin/env bash

caminho_pen="/run/media/darkouto/PEN_IVECO"

if [[ ! -d "$caminho_pen" ]]; then
    echo "ERRO: Caminho da PEN não encontrado!"
    exit 1
fi

echo "A iniciar processo de copiar todas as pastas..."
for pasta in */; do
    mkdir -vp "$caminho_pen/$pasta"
    cp -v "$pasta"* "$caminho_pen/$pasta"
done

echo "A reescrever o índice da PEN Drive..."
sync

echo "A eliminar ficheiros de indexação..."
find "$caminho_pen" -name ".*" -exec rm -rf {} +

echo "Processo Concluído!"
